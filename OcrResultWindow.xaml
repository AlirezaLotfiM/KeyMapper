<Window x:Class="KeyMapper.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen text"
        Width="560"
        Height="500"
        MinWidth="440"
        MinHeight="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="OcrButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrIconButton" TargetType="Button" BasedOn="{StaticResource OcrButton}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="3"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="6" Color="#6B5A3A" Opacity="0.35"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="7"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#55CAD3"/>
                <Border Grid.Column="1" Background="#F3BE55"/>
                <Border Grid.Column="2" Background="#E985AE"/>
            </Grid>

            <Grid Grid.Row="1" Margin="24,20,20,18"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Screen text"
                               Foreground="{DynamicResource AppTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Review what your companion found before using it."
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource OcrIconButton}"
                        BorderBrush="#D795AA"
                        ToolTip="Close OCR result"
                        Click="CloseButton_Click">
                    <Grid Width="24" Height="24">
                        <Path Width="12" Height="12"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Fill"
                              Data="M18 18L12 12M12 12L6 6M12 12L18 6M12 12L6 18"
                              Stroke="#B53D64"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Grid>
                </Button>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,2,0,2"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#D4F1E2"
                            BorderBrush="#53A77D"
                            BorderThickness="2"
                            Padding="9,5"
                            Margin="0,0,12,0">
                        <TextBlock Text="OCR READY"
                                   Foreground="#246548"
                                   FontFamily="Segoe UI"
                                   FontWeight="SemiBold"
                                   FontSize="10"/>
                    </Border>
                    <TextBlock x:Name="DetailsText"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="24,20,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Recognized text"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="RecognizedTextBox"
                         Grid.Row="1"
                         Background="{DynamicResource AppInputBrush}"
                         Foreground="{DynamicResource AppTextBrush}"
                         CaretBrush="{DynamicResource AppAccentBrush}"
                         BorderBrush="{DynamicResource AppBorderBrush}"
                         BorderThickness="2"
                         Padding="14"
                         FontFamily="Segoe UI"
                         FontSize="14"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         SelectionBrush="{DynamicResource AppAccentSoftBrush}"/>
            </Grid>

            <Grid Grid.Row="4" Margin="24,18,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ActionStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Text="Edit anything before using it."/>
                <Button Grid.Column="1"
                        Style="{StaticResource OcrButton}"
                        Margin="12,0,10,0"
                        Click="CopyButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="17" Height="17" Margin="0,0,8,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M6 11C6 8.17157 6 6.75736 6.87868 5.87868C7.75736 5 9.17157 5 12 5H15C17.8284 5 19.2426 5 20.1213 5.87868C21 6.75736 21 8.17157 21 11V16C21 18.8284 21 20.2426 20.1213 21.1213C19.2426 22 17.8284 22 15 22H12C9.17157 22 7.75736 22 6.87868 21.1213C6 20.2426 6 18.8284 6 16V11Z"
                                      Stroke="#30445E" StrokeThickness="1.7"/>
                                <Path Data="M6 19C4.34315 19 3 17.6569 3 16V10C3 6.22876 3 4.34315 4.17157 3.17157C5.34315 2 7.22876 2 11 2H15C16.6569 2 18 3.34315 18 5"
                                      Stroke="#6B7B8F" StrokeThickness="1.7" Opacity="0.65"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Copy text" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Style="{StaticResource OcrButton}"
                        Background="{DynamicResource AppAccentSoftBrush}"
                        BorderBrush="{DynamicResource AppAccentBrush}"
                        Click="TranslateButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Translate" VerticalAlignment="Center"/>
                        <TextBlock Text="→" FontSize="16" Margin="8,-1,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>

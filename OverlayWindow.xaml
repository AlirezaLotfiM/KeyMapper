<Window x:Class="KeyMapper.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyMapper HUD" 
        Height="50" 
        Width="260"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False" 
        Focusable="False" 
        IsHitTestVisible="False">
    <Grid>
        <Border Background="#E61E1E24" CornerRadius="25" BorderBrush="#33FFFFFF" BorderThickness="1.5">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Pulsing red dot -->
                <Ellipse x:Name="RecordingDot" Grid.Column="0" Width="10" Height="10" Fill="#FF3B30" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="RecordingDot" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     From="0.2" To="1.0" Duration="0:0:0.5" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Rec: " Foreground="#8E8E93" FontSize="13" FontFamily="Segoe UI" FontWeight="Medium" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BufferText" Text="..." Foreground="#FFFFFF" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

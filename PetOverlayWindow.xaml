<Window x:Class="KeyMapper.PetOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Pet Assistant"
        Icon="/Resources/app_icon.ico"
        Height="280" Width="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        MouseDown="Window_MouseDown"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <Storyboard x:Key="IdleAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="PetBodyTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-2" Duration="0:0:2.4" />
            <DoubleAnimation Storyboard.TargetName="PetScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.04" Duration="0:0:1.6" />
        </Storyboard>

        <Storyboard x:Key="ListeningAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="0.95" Duration="0:0:0.5" />
            <DoubleAnimation Storyboard.TargetName="PetBodyTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-5" Duration="0:0:0.5" />
        </Storyboard>
    </Window.Resources>

    <Grid Margin="10">

        <!-- Speech Bubble Container -->
        <Border x:Name="SpeechBubble"
                Background="{DynamicResource AppBackgroundBrush}" CornerRadius="8" Padding="12,8"
                Margin="10,0,10,10" BorderBrush="{DynamicResource AppAccentBrush}" BorderThickness="2"
                Visibility="Collapsed" HorizontalAlignment="Center"
                VerticalAlignment="Top" MaxWidth="320" Panel.ZIndex="2">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#6B5A3A" Opacity="0.3" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="SpeechBubbleTitle" Text="Chubby Android Pet"
                           Foreground="{DynamicResource AppAccentBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock x:Name="SpeechBubbleText" Text="Beep boop! Ready to automate!"
                           Foreground="{DynamicResource AppTextBrush}" FontSize="12" TextWrapping="Wrap" MaxHeight="120"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>

        <!-- Pet Character Canvas -->
        <Grid Height="140" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <!-- Main Sprite Graphic Group -->
            <Canvas Width="140" Height="140" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform x:Name="PetBodyTransform" Y="0"/>
                        <ScaleTransform x:Name="PetScaleTransform" ScaleX="1.0" ScaleY="1.0" CenterX="70" CenterY="70"/>
                    </TransformGroup>
                </Canvas.RenderTransform>

                <!-- A tight contact shadow keeps the sprite grounded without a detached halo. -->
                <Ellipse Canvas.Left="46" Canvas.Top="107" Width="48" Height="6" Fill="#26000000">
                    <Ellipse.Effect>
                        <BlurEffect Radius="2"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Canvas.Left="56" Canvas.Top="108" Width="28" Height="3" Fill="#42000000"/>

                <!-- 2D Pixel Art Sprite Image -->
                <Image x:Name="PetSpriteImage"
                       Width="120" Height="120"
                       Canvas.Left="10" Canvas.Top="4"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       RenderOptions.EdgeMode="Aliased"/>

                <!-- Status Badge Indicator -->
                <Border x:Name="StatusBadge" Canvas.Left="95" Canvas.Top="15"
                        Background="#10B981" CornerRadius="8" Padding="6,2" Visibility="Collapsed">
                    <TextBlock x:Name="StatusBadgeText" Text="AI" Foreground="#0F172A" FontSize="9" FontWeight="Bold"/>
                </Border>
            </Canvas>
        </Grid>
    </Grid>

    <Window.ContextMenu>
        <ContextMenu Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource AppTextBrush}" BorderBrush="{DynamicResource AppTextBrush}" BorderThickness="2" Padding="2" FontFamily="Segoe UI" FontSize="12">
            <ContextMenu.Resources>
                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                    <Setter Property="MinWidth" Value="238"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type MenuItem}">
                                <Grid>
                                <Border x:Name="PixelCell" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1" SnapsToDevicePixels="True">
                                    <Grid Height="29">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="22"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle x:Name="PixelMarker" Grid.Column="0" Fill="{DynamicResource AppAccentBrush}" Visibility="Collapsed"/>
                                        <ContentPresenter Grid.Column="1"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          ContentSource="Icon"/>
                                        <ContentPresenter Grid.Column="2" Margin="5,0,4,0" VerticalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                                        <TextBlock x:Name="Arrow" Grid.Column="3" Text="›" FontSize="17" Foreground="{DynamicResource AppAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <!-- WPF requires PART_Popup to display nested menu items. -->
                                <Popup x:Name="PART_Popup"
                                       Placement="Right"
                                       HorizontalOffset="-2"
                                       VerticalOffset="-2"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="{DynamicResource AppBackgroundBrush}"
                                            BorderBrush="{DynamicResource AppTextBrush}"
                                            BorderThickness="2"
                                            Padding="2"
                                            SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="HasItems" Value="True">
                                        <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="PixelCell" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                        <Setter TargetName="PixelCell" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                        <Setter TargetName="PixelMarker" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type Separator}">
                    <Setter Property="Height" Value="3"/>
                    <Setter Property="Margin" Value="7,4"/>
                    <Setter Property="Template">
                            <Setter.Value><ControlTemplate TargetType="{x:Type Separator}"><Border Background="{DynamicResource AppBorderBrush}" Height="1"/></ControlTemplate></Setter.Value>
                    </Setter>
                </Style>
                <Style x:Key="PetMenuIcon" TargetType="Rectangle">
                    <Setter Property="Width" Value="15"/>
                    <Setter Property="Height" Value="15"/>
                    <Setter Property="Fill" Value="{DynamicResource AppAccentBrush}"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="Talk to Character" Click="MenuAsk_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/chat.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="De-gibberish selected text (Ctrl+Alt+K)" Click="MenuDeGibberish_Click"
                      ToolTip="Turns text typed under the wrong Persian, English, or German keyboard layout back into the intended text.">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/keyboard.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Translate Selected Text" Click="MenuTranslate_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/translate.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="OCR Screen Snipper" Click="MenuOcr_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/ocr.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Switch Character">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/character.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
                <MenuItem Header="Pink Monster" Click="MenuCharPink_Click"/>
                <MenuItem Header="Owlet Monster" Click="MenuCharOwlet_Click"/>
                <MenuItem Header="Dude Monster" Click="MenuCharDude_Click"/>
            </MenuItem>
            <MenuItem Header="Walking: On" Click="MenuToggleWalking_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/walking.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Movement Speed">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/speed.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
                <MenuItem Header="Slow" Tag="45" Click="MenuSetWalkingSpeed_Click"/>
                <MenuItem Header="Normal" Tag="92" Click="MenuSetWalkingSpeed_Click"/>
                <MenuItem Header="Fast" Tag="160" Click="MenuSetWalkingSpeed_Click"/>
            </MenuItem>
            <MenuItem Header="Idle Animation Speed">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/idle.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
                <MenuItem Header="Calm" Tag="750" Click="MenuSetIdleSpeed_Click"/>
                <MenuItem Header="Normal" Tag="430" Click="MenuSetIdleSpeed_Click"/>
                <MenuItem Header="Lively" Tag="220" Click="MenuSetIdleSpeed_Click"/>
            </MenuItem>
            <MenuItem x:Name="CommentsToggleMenuItem" Header="Comments: On" Click="MenuToggleComments_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/chat.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="AiCommentsToggleMenuItem" Header="Fresh AI Comments: On" Click="MenuToggleAiComments_Click"
                      ToolTip="Uses only a downloaded local model. Window and music titles never go to a hosted service.">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/ai.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Comment Frequency">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/sound.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
                <MenuItem x:Name="CommentsQuietMenuItem" Header="Quiet" Tag="Quiet" Click="MenuSetCommentFrequency_Click"/>
                <MenuItem x:Name="CommentsNormalMenuItem" Header="Normal" Tag="Normal" Click="MenuSetCommentFrequency_Click"/>
                <MenuItem x:Name="CommentsChattyMenuItem" Header="Chatty" Tag="Chatty" Click="MenuSetCommentFrequency_Click"/>
            </MenuItem>
            <MenuItem Header="Open KeyMapper Settings" Click="MenuSettings_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/settings.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Hide Desktop Pet" Click="MenuHide_Click">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/hide.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Exit Desktop Pet" Click="MenuExit_Click" Foreground="#B53D64">
                <MenuItem.Icon>
                    <Rectangle Style="{StaticResource PetMenuIcon}" Fill="#B53D64">
                        <Rectangle.OpacityMask><ImageBrush ImageSource="Resources/Icons/exit.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>
</Window>

<Window x:Class="KeyMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KeyMapper"
        Title="Desktop Pet Control Center"
        Icon="Resources/app_icon.ico"
        Height="680" 
        Width="920"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}"
        FontFamily="Segoe UI"
        BorderThickness="0">
    
    <Window.Resources>
        <!-- Modern ScrollViewer style for listboxes/datagrids supporting both vertical and horizontal layouts -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="0"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track" IsDirectionReversed="false">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="0"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Shared ListViewItem style with stretch content alignment -->
        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom tab item style -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="16,10" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniChip" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppAccentFillBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource AppAccentBrush}" BorderThickness="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChoiceCardItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="SettingsIconTile" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Desktop Pet Control Center" FontFamily="Segoe UI" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center"/>
                <!-- Status Badge -->
                <Border x:Name="StatusBadge" Margin="14,0,0,0" Padding="10,5" BorderBrush="#53A77D" BorderThickness="1" Background="#E1F4EA" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="KeyMapper is on" Foreground="#246548" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Disable / Enable Button -->
                <Button x:Name="ToggleHookBtn" Content="Disable KeyMapper" Style="{StaticResource SecondaryButton}" Click="ToggleHook_Click" Margin="0,0,10,0"/>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0">
            
            <!-- Tab 1: Text Replacements -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                   Margin="0,0,7,0">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="Resources/Icons/mappings.png"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="Text Expansions"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Replacements List -->
                    <ListView x:Name="ReplacementsList" Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Margin="0,0,0,15" Padding="5" MouseDoubleClick="ReplacementsList_MouseDoubleClick" ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Shortcut}" Foreground="{DynamicResource AppAccentBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Target}" Foreground="{DynamicResource AppTextBrush}" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AllowedProcessDisplay}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ExcludedProcessDisplay}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <CheckBox Grid.Column="4" Content="Auto-Expand" IsChecked="{Binding IsAutoExpand, Mode=TwoWay}" Foreground="{DynamicResource AppMutedTextBrush}" VerticalAlignment="Center" FontSize="12" Click="SettingChanged"/>
                                    <Button Grid.Column="5" Click="DeleteReplacement_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                        <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#FF453A" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="16,13">
                        <StackPanel>
                            <TextBlock Text="Create a text expansion" Foreground="{DynamicResource AppTextBrush}" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Choose a short trigger and the text that should replace it."
                                       Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,2,0,11"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="46"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="When I type"
                                           Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Replace it with"
                                           Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,5"/>

                                <TextBox Grid.Row="1" Grid.Column="0" x:Name="AddRepShortcutTxt"
                                         Height="34" VerticalAlignment="Center" ToolTip="Example: mail"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="→"
                                           Foreground="{DynamicResource AppAccentBrush}" FontSize="17"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="2" x:Name="AddRepTargetTxt"
                                         Height="46" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap" AcceptsTab="True" ToolTip="Example: mymail@mail.ir"/>

                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Add dynamic value:" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <Button Content="{}{date}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{date}"/>
                                    <Button Content="{}{time}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{time}"/>
                                    <Button Content="{}{clip}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{clip}"/>
                                    <Button Content="{}{sel}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{sel}"/>
                                    <Button Content="{}{cursor}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{cursor}"/>
                                </StackPanel>
                            </Grid>

                            <Expander Margin="0,10,0,0" Foreground="{DynamicResource AppTextBrush}">
                                <Expander.Header>
                                    <TextBlock Text="Limit this expansion to specific apps (optional)"
                                               FontWeight="SemiBold" FontSize="11"/>
                                </Expander.Header>
                                <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                        Padding="12,10" Margin="0,7,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Leave both fields blank to use the expansion everywhere."
                                                   Foreground="{DynamicResource AppMutedTextBrush}" FontSize="10" Margin="0,0,0,9"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Only use in this app" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="AddRepAllowedProcessTxt" Height="32"/>
                                                    <Button Grid.Column="1" Content="Running app" Style="{StaticResource SecondaryButton}"
                                                            Click="PickAllowedRepApp_Click" Height="32" Margin="8,0,0,0"/>
                                                    <Button Grid.Column="2" Content="Choose file" Style="{StaticResource SecondaryButton}"
                                                            Click="BrowseAllowedRepApp_Click" Height="32" Margin="8,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Never use in this app" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="AddRepExcludedProcessTxt" Height="32"/>
                                                    <Button Grid.Column="1" Content="Running app" Style="{StaticResource SecondaryButton}"
                                                            Click="PickExcludedRepApp_Click" Height="32" Margin="8,0,0,0"/>
                                                    <Button Grid.Column="2" Content="Choose file" Style="{StaticResource SecondaryButton}"
                                                            Click="BrowseExcludedRepApp_Click" Height="32" Margin="8,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <Button Content="Save expansion" Style="{StaticResource PrimaryButton}"
                                    Click="AddReplacement_Click" HorizontalAlignment="Right"
                                    Height="34" Padding="20,0" Margin="0,11,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Actions -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                   Margin="0,0,7,0">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="Resources/Icons/active.png"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="App Actions"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Actions List -->
                    <ListView x:Name="ActionsList" Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Margin="0,0,0,15" Padding="5" MouseDoubleClick="ActionsList_MouseDoubleClick" ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Shortcut}" Foreground="#2F8A63" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Target}" Foreground="{DynamicResource AppTextBrush}" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AllowedProcessDisplay}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ExcludedProcessDisplay}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="4" Click="DeleteAction_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                        <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#FF453A" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Row 0: Abbr & Target -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Abbreviation (e.g. tlg)" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActShortcutTxt" Height="32"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="App Path or Command (e.g. calc.exe)" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActTargetTxt" Height="50" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsTab="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Insert: " Foreground="{DynamicResource AppMutedTextBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <Button Content="{}{date}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{date}"/>
                                        <Button Content="{}{time}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{time}"/>
                                        <Button Content="{}{clip}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{clip}"/>
                                        <Button Content="{}{sel}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{sel}"/>
                                        <Button Content="{}{cursor}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{cursor}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,16,0,0">
                                    <Button Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickActTargetApp_Click" Height="32" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseApp_Click" Height="32"/>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Allowed App & Excluded App -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Allowed App -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Allowed App (optional)" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActAllowedProcessTxt" Height="32"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickAllowedActApp_Click" VerticalAlignment="Bottom" Height="32" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseAllowedActApp_Click" VerticalAlignment="Bottom" Height="32"/>

                                <!-- Excluded App -->
                                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                    <TextBlock Text="Excluded App (optional)" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActExcludedProcessTxt" Height="32"/>
                                </StackPanel>
                                <Button Grid.Column="5" Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickExcludedActApp_Click" VerticalAlignment="Bottom" Height="32" Margin="0,0,10,0"/>
                                <Button Grid.Column="6" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseExcludedActApp_Click" VerticalAlignment="Bottom" Height="32"/>

                                <Button Grid.Column="8" Content="Add Action" Style="{StaticResource PrimaryButton}" Click="AddAction_Click" VerticalAlignment="Bottom" Height="32" Padding="20,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Settings -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                   Margin="0,0,7,0">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="Resources/Icons/settings.png"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="Settings"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:SmoothScrollViewer Grid.Row="0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,0,20">
                            <!-- Toggle Options -->
                            <Border Style="{StaticResource SettingsSection}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,18">
                                        <Border Style="{StaticResource SettingsIconTile}">
                                            <Rectangle Width="22" Height="22"
                                                       Fill="{DynamicResource AppAccentBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="Resources/Icons/everyday.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Everyday Settings"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Basic behavior for shortcuts, startup, and sounds."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                    
                                    <CheckBox x:Name="SuppressKeysChk" Content="Keep shortcut keystrokes out of the active app" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <TextBlock Text="If checked, the keys you type after Left Ctrl will not be sent to the active application until you cancel or submit." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="20,0,0,15"/>

                                    <CheckBox x:Name="ShowOverlayChk" Content="Show what I am typing for a shortcut" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <TextBlock Text="Displays a small overlay at the bottom right showing current typed trigger." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="20,0,0,15"/>

                                    <CheckBox x:Name="RunAtStartupChk" Content="Launch the desktop pet when I sign in to Windows" Foreground="{DynamicResource AppTextBrush}" Checked="SettingChanged" Unchecked="SettingChanged" Margin="0,0,0,12"/>
                                    <TextBlock Text="Off by default. Uncheck this at any time to opt out; it affects only your Windows account." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="20,0,0,15"/>

                                    <CheckBox x:Name="PlaySoundsChk" Content="Play sounds when an action succeeds" Foreground="{DynamicResource AppTextBrush}" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <TextBlock Text="Plays mechanical click sounds when recording, and a chime when a shortcut triggers." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="20,0,0,5"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsSection}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,16">
                                        <Border Style="{StaticResource SettingsIconTile}">
                                            <Rectangle Width="22" Height="22"
                                                       Fill="{DynamicResource AppAccentBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="Resources/Icons/appearance.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Appearance"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Pick a palette. The preview strip shows its background, surface, and accent."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <ListBox x:Name="ThemePicker"
                                             ItemsSource="{x:Static local:ThemeManager.Themes}"
                                             SelectedValuePath="Id"
                                             SelectionChanged="ThemePicker_SelectionChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource ChoiceCardItem}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="82">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="10"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"/>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,5,0,10"/>
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{Binding PreviewBackground}"/>
                                                        <Border Grid.Column="1" Background="{Binding PreviewSurface}"/>
                                                        <Border Grid.Column="2" Background="{Binding PreviewAccent}"/>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsSection}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,16">
                                        <Border Style="{StaticResource SettingsIconTile}">
                                            <Rectangle Width="22" Height="22"
                                                       Fill="{DynamicResource AppAccentBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="Resources/Icons/ai.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Conversation AI"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"/>
                                                <Border Background="{DynamicResource AppAccentSoftBrush}"
                                                        BorderBrush="{DynamicResource AppAccentBrush}"
                                                        BorderThickness="1"
                                                        Padding="7,2"
                                                        Margin="9,0,0,0">
                                                    <TextBlock Text="OPTIONAL"
                                                               Foreground="{DynamicResource AppAccentBrush}"
                                                               FontSize="9"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Download only the model you want. The pet works normally without one."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Border Background="{DynamicResource AppSurfaceAltBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Width="20" Height="20"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       Fill="{DynamicResource AppAccentBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="Resources/Icons/active.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="LocalAiRecommendationTxt"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="LocalAiHardwareTxt"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Choose one model"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10"/>
                                    <ListBox x:Name="LocalAiModelPicker"
                                             ItemsSource="{x:Static local:LocalAiService.Models}"
                                             SelectedValuePath="Id"
                                             SelectionChanged="LocalAiModelPicker_SelectionChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource ChoiceCardItem}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             Margin="0,0,0,8">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="104">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"/>
                                                    <StackPanel Grid.Row="1"
                                                                Orientation="Horizontal"
                                                                Margin="0,7,0,7">
                                                        <Border Background="{DynamicResource AppAccentSoftBrush}"
                                                                Padding="7,3"
                                                                Margin="0,0,7,0">
                                                            <TextBlock Text="{Binding DownloadSize}"
                                                                       Foreground="{DynamicResource AppAccentBrush}"
                                                                       FontSize="10"/>
                                                        </Border>
                                                        <Border Background="{DynamicResource AppSurfaceAltBrush}"
                                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                                BorderThickness="1"
                                                                Padding="7,2">
                                                            <TextBlock Text="{Binding MemoryLabel}"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                                       FontSize="10"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding Description}"
                                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border Background="{DynamicResource AppSurfaceAltBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            Padding="15"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock x:Name="LocalAiDescriptionTxt"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,12"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="LocalAiDownloadBtn"
                                                        Grid.Column="0"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Click="LocalAiDownload_Click"
                                                        Height="36"
                                                        Padding="14,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="16" Height="16"
                                                                   Fill="{DynamicResource AppTextBrush}"
                                                                   Margin="0,0,7,0">
                                                            <Rectangle.OpacityMask>
                                                                <ImageBrush ImageSource="Resources/Icons/import.png"/>
                                                            </Rectangle.OpacityMask>
                                                        </Rectangle>
                                                        <TextBlock x:Name="LocalAiDownloadLabel"
                                                                   Text="Download model"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="LocalAiRemoveBtn"
                                                        Grid.Column="2"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="LocalAiRemove_Click"
                                                        Height="36"
                                                        Padding="13,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="15" Height="15"
                                                                   Fill="#B53D64"
                                                                   Margin="0,0,7,0">
                                                            <Rectangle.OpacityMask>
                                                                <ImageBrush ImageSource="Resources/Icons/delete.png"/>
                                                            </Rectangle.OpacityMask>
                                                        </Rectangle>
                                                        <TextBlock Text="Remove" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <ProgressBar x:Name="LocalAiProgress"
                                                                 Height="8"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Visibility="Collapsed"/>
                                                    <TextBlock x:Name="LocalAiStatusTxt"
                                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource AppBackgroundBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <CheckBox x:Name="LocalAiEnabledChk"
                                                      Content="Use the downloaded model for conversations"
                                                      Foreground="{DynamicResource AppTextBrush}"
                                                      Checked="SettingChanged"
                                                      Unchecked="SettingChanged"
                                                      Margin="0,0,0,10"/>
                                            <CheckBox x:Name="AiAmbientCommentsChk"
                                                      Content="Let local AI add fresh comments about apps and music"
                                                      Foreground="{DynamicResource AppTextBrush}"
                                                      Checked="SettingChanged"
                                                      Unchecked="SettingChanged"
                                                      Margin="0,0,0,5"/>
                                            <TextBlock Text="Background comments remain private. Only the current window title or music title and artist are sent to the downloaded model."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="20,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource AppSurfaceAltBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="2"
                                            Padding="14"
                                            Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Rectangle Width="22" Height="22"
                                                           Fill="{DynamicResource AppAccentBrush}"
                                                           Margin="0,0,10,0"
                                                           VerticalAlignment="Top">
                                                    <Rectangle.OpacityMask>
                                                        <ImageBrush ImageSource="Resources/Icons/cloud.png"/>
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                                <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="PixelYar Cloud"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"/>
                                                    <Border Background="{DynamicResource AppAccentSoftBrush}"
                                                            BorderBrush="{DynamicResource AppAccentBrush}"
                                                            BorderThickness="1"
                                                            Padding="7,2"
                                                            Margin="9,0,0,0">
                                                        <TextBlock Text="PREVIEW"
                                                                   Foreground="{DynamicResource AppAccentBrush}"
                                                                   FontWeight="Bold"
                                                                   FontSize="9"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="No model download. The hosted chat is usable in the browser while its in-app API connection is still being finished."
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,7,14,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Click="OpenCloudAi_Click"
                                                    Padding="14,0"
                                                    Height="34"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Rectangle Width="15" Height="15"
                                                               Fill="{DynamicResource AppAccentBrush}"
                                                               Margin="0,0,7,0">
                                                        <Rectangle.OpacityMask>
                                                            <ImageBrush ImageSource="Resources/Icons/chat.png"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                    <TextBlock Text="Open cloud chat" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <Expander Header="Advanced · Use my own compatible AI service"
                                              Foreground="{DynamicResource AppTextBrush}">
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Text="Computer actions still use the safe local command system. These fields only affect natural conversation."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="Chat-completions endpoint"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,5"/>
                                            <TextBox x:Name="AiEndpointTxt"
                                                     Height="32"
                                                     TextChanged="SettingChanged"
                                                     ToolTip="A hosted /v1/chat/completions URL or a compatible local server."
                                                     Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="220"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="API key (optional for local servers)"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,5"/>
                                                    <PasswordBox x:Name="AiApiKeyTxt"
                                                                 Height="32"
                                                                 PasswordChanged="SettingChanged"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Model name"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,5"/>
                                                    <TextBox x:Name="AiModelTxt"
                                                             Height="32"
                                                             TextChanged="SettingChanged"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- Backup & Restore -->
                            <Border Style="{StaticResource SettingsSection}"
                                    Background="{DynamicResource AppSurfaceAltBrush}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,14">
                                        <Border Style="{StaticResource SettingsIconTile}">
                                            <Rectangle Width="22" Height="22"
                                                       Fill="{DynamicResource AppAccentBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="Resources/Icons/backup.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Backup and Restore"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Move expansions and actions between installations."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Click="ExportMappings_Click"
                                                Margin="0,0,12,0"
                                                Padding="14,0"
                                                Height="34">
                                            <StackPanel Orientation="Horizontal">
                                                <Rectangle Width="15" Height="15"
                                                           Fill="{DynamicResource AppAccentBrush}"
                                                           Margin="0,0,7,0">
                                                    <Rectangle.OpacityMask>
                                                        <ImageBrush ImageSource="Resources/Icons/export.png"/>
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                                <TextBlock Text="Export mappings" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Click="ImportMappings_Click"
                                                Padding="14,0"
                                                Height="34">
                                            <StackPanel Orientation="Horizontal">
                                                <Rectangle Width="15" Height="15"
                                                           Fill="{DynamicResource AppAccentBrush}"
                                                           Margin="0,0,7,0">
                                                    <Rectangle.OpacityMask>
                                                        <ImageBrush ImageSource="Resources/Icons/import.png"/>
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                                <TextBlock Text="Import mappings" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Exclusions -->
                            <Border Style="{StaticResource SettingsSection}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                        <Border Style="{StaticResource SettingsIconTile}">
                                            <Rectangle Width="22" Height="22"
                                                       Fill="{DynamicResource AppAccentBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="Resources/Icons/exclusions.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Apps Where Features Stay Off"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="KeyMapper ignores every app listed below."
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                    
                                    <ListView x:Name="ExclusionsList" Grid.Row="1" Height="120" Background="{DynamicResource AppInputBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Margin="0,0,0,10" Padding="5">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding}" Foreground="{DynamicResource AppTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Click="DeleteExclusion_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                                        <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#FF453A" Width="12" Height="12" Stretch="Uniform"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AddExclusionTxt" Margin="0,0,10,0"/>
                                        <Button Grid.Column="1" Content="Add app" Style="{StaticResource SecondaryButton}" Click="AddExclusion_Click" Height="32" Padding="12,0" Margin="0,0,10,0"/>
                                        <Button Grid.Column="2" Content="Choose running apps" Style="{StaticResource SecondaryButton}" Click="SelectExclusionApps_Click" Height="32" Padding="12,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </local:SmoothScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 4: User Guide -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                   Margin="0,0,7,0">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="Resources/Icons/guide.png"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="User Guide"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,15,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel Margin="0,0,0,20">
                            <!-- Welcome Header -->
                            <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Welcome to Desktop Pet" FontFamily="Segoe UI" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppAccentBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Your companion can expand text, run actions, de-gibberish text typed under the wrong keyboard layout, translate selected text, read the screen with OCR, and offer context-aware help." Foreground="{DynamicResource AppTextBrush}" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Modes of Operation -->
                            <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="1. How Shortcuts Work" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="• Auto-Expand Mode (Trigger Character)" FontWeight="SemiBold" Foreground="#30D158" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock Text="Type your abbreviation followed by a semicolon (e.g. typing 'mail;' where 'mail' is mapped). The abbreviation is instantly erased and replaced by your expanded text. Perfect for fast, uninterrupted typing." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="10,0,0,12" LineHeight="16"/>

                                    <TextBlock Text="• Standard Mode (Interception Buffer)" FontWeight="SemiBold" Foreground="#30D158" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock Text="Tap Left Ctrl (starts recording a mechanical click sound) → Type your abbreviation (e.g. 'mail') → Tap Right Ctrl (submits). The text is replaced. To cancel recording, tap Left Ctrl again." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="10,0,0,0" LineHeight="16"/>
                                </StackPanel>
                            </Border>

                            <!-- Text Expansions & Macros -->
                            <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="2. Dynamic Text Pieces" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12"/>
                                    <TextBlock Text="These placeholders automatically insert useful information into an expansion:" Foreground="{DynamicResource AppTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    
                                    <TextBlock Text="• {date}: Inserts the current local date (e.g. 2026-07-20)." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {time}: Inserts the current local time (e.g. 23:51)." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {clip}: Pastes the current contents of your clipboard." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {sel}: Grabs the active text selection and inserts it." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {cursor}: Places your keyboard cursor at this position after pasting." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Text Functions -->
                            <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="3. Advanced Text Functions" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Advanced users can prefix a target with 'fn:' to transform selected or typed text:" Foreground="{DynamicResource AppTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="18"/>
                                    
                                    <Grid Margin="10,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="fn:upper" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Converts text to UPPERCASE." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="fn:lower" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Converts text to lowercase." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="fn:title" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Converts text to Title Case (Capitalizes Words)." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="fn:rev / fn:reverse" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Reverses the text string (e.g. 'hello' → 'olleh')." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="fn:len" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Returns the character length of the input." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="fn:calc" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Evaluates mathematical expressions (e.g. '12*3' → '36')." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="fn:morse / fn:mc" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Converts text to Morse Code." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="fn:unmorse / fn:umc" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="Translates Morse Code back to text (supports Unicode middle dots, bullets, and dashes)." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,4,0,4"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Scope Control -->
                            <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="4. Choose Where Features Work" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12"/>
                                    <TextBlock Text="You can allow a shortcut only in one app, block it in one app, or disable all features in selected apps." Foreground="{DynamicResource AppTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="18"/>
                                    
                                    <TextBlock Text="• Allowed App: The shortcut will ONLY trigger when this program is active." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Excluded App: The shortcut will trigger everywhere EXCEPT in this program." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Pick Button: Choose from a list of currently running windows." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Browse Button: Select the executable file (.exe) path from your disk." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Shortcuts and Controls -->
                            <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="5. Keyboard Controls" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="• Ctrl + Alt + P: Global Pause/Resume shortcut. Swallows keys so it doesn't type." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Ctrl + Alt + K: De-gibberish selected text. Example: Persian-layout اثممخ becomes hello." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="• Scroll Lock: Alternative Pause/Resume toggle key." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Minimize Window: Closing the main window automatically minimizes it to the system tray. Use the tray icon menu to open the dashboard or fully Exit." Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="10,0,0,0" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

<Window x:Class="KeyMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyMapper Control Center" 
        Height="680" 
        Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#121214"
        Foreground="#F2F2F7"
        FontFamily="Segoe UI"
        BorderThickness="0">
    
    <Window.Resources>
        <!-- Modern ScrollViewer style for listboxes/datagrids supporting both vertical and horizontal layouts -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#3A3A3C" CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track" IsDirectionReversed="false">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#3A3A3C" CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Shared ListViewItem style with stretch content alignment -->
        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C2C2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom tab item style -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="16,10" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#007AFF"/>
                                <Setter Property="Foreground" Value="#007AFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#8E8E93"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1C1C1E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2C2C2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="#007AFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniChip" TargetType="Button">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#007AFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0066D6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#004C99"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#F2F2F7"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C1C1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="KeyMapper v1.1.0" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                <!-- Status Badge -->
                <Border x:Name="StatusBadge" Margin="15,0,0,0" Padding="8,4" CornerRadius="12" Background="#1C2E24" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="ACTIVE" Foreground="#30D158" FontSize="11" FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Disable / Enable Button -->
                <Button x:Name="ToggleHookBtn" Content="Disable KeyMapper" Style="{StaticResource SecondaryButton}" Click="ToggleHook_Click" Margin="0,0,10,0"/>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0">
            
            <!-- Tab 1: Text Replacements -->
            <TabItem Header="Text Expansions">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Replacements List -->
                    <ListView x:Name="ReplacementsList" Grid.Row="0" Background="#1C1C1E" BorderThickness="0" Margin="0,0,0,15" Padding="5" MouseDoubleClick="ReplacementsList_MouseDoubleClick" ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Shortcut}" Foreground="#007AFF" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Target}" Foreground="#E5E5EA" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AllowedProcessDisplay}" Foreground="#8E8E93" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ExcludedProcessDisplay}" Foreground="#8E8E93" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <CheckBox Grid.Column="4" Content="Auto-Expand" IsChecked="{Binding IsAutoExpand, Mode=TwoWay}" Foreground="#8E8E93" VerticalAlignment="Center" FontSize="12" Click="SettingChanged"/>
                                    <Button Grid.Column="5" Click="DeleteReplacement_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                        <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#FF453A" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Background="#1C1C1E" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Row 0: Abbr & Target -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Abbreviation (e.g. mail)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddRepShortcutTxt" Height="32"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Expanded Text (e.g. mymail@mail.ir)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddRepTargetTxt" Height="50" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsTab="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Insert: " Foreground="#8E8E93" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <Button Content="{}{date}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{date}"/>
                                        <Button Content="{}{time}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{time}"/>
                                        <Button Content="{}{clip}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{clip}"/>
                                        <Button Content="{}{sel}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{sel}"/>
                                        <Button Content="{}{cursor}" Style="{StaticResource MiniChip}" Click="InsertRepMacro_Click" Tag="{}{cursor}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Allowed App & Excluded App -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Allowed App -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Allowed App (optional)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddRepAllowedProcessTxt" Height="32"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickAllowedRepApp_Click" VerticalAlignment="Bottom" Height="32" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseAllowedRepApp_Click" VerticalAlignment="Bottom" Height="32"/>

                                <!-- Excluded App -->
                                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                    <TextBlock Text="Excluded App (optional)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddRepExcludedProcessTxt" Height="32"/>
                                </StackPanel>
                                <Button Grid.Column="5" Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickExcludedRepApp_Click" VerticalAlignment="Bottom" Height="32" Margin="0,0,10,0"/>
                                <Button Grid.Column="6" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseExcludedRepApp_Click" VerticalAlignment="Bottom" Height="32"/>

                                <Button Grid.Column="8" Content="Add Expansion" Style="{StaticResource PrimaryButton}" Click="AddReplacement_Click" VerticalAlignment="Bottom" Height="32" Padding="20,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Actions -->
            <TabItem Header="App Actions">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Actions List -->
                    <ListView x:Name="ActionsList" Grid.Row="0" Background="#1C1C1E" BorderThickness="0" Margin="0,0,0,15" Padding="5" MouseDoubleClick="ActionsList_MouseDoubleClick" ItemContainerStyle="{StaticResource ModernListViewItem}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Shortcut}" Foreground="#30D158" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Target}" Foreground="#E5E5EA" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AllowedProcessDisplay}" Foreground="#8E8E93" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ExcludedProcessDisplay}" Foreground="#8E8E93" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="4" Click="DeleteAction_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                        <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#FF453A" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Background="#1C1C1E" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Row 0: Abbr & Target -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Abbreviation (e.g. tlg)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActShortcutTxt" Height="32"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="App Path or Command (e.g. calc.exe)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActTargetTxt" Height="50" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsTab="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Insert: " Foreground="#8E8E93" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <Button Content="{}{date}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{date}"/>
                                        <Button Content="{}{time}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{time}"/>
                                        <Button Content="{}{clip}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{clip}"/>
                                        <Button Content="{}{sel}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{sel}"/>
                                        <Button Content="{}{cursor}" Style="{StaticResource MiniChip}" Click="InsertActMacro_Click" Tag="{}{cursor}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,16,0,0">
                                    <Button Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickActTargetApp_Click" Height="32" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseApp_Click" Height="32"/>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Allowed App & Excluded App -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Allowed App -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Allowed App (optional)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActAllowedProcessTxt" Height="32"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickAllowedActApp_Click" VerticalAlignment="Bottom" Height="32" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseAllowedActApp_Click" VerticalAlignment="Bottom" Height="32"/>

                                <!-- Excluded App -->
                                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                    <TextBlock Text="Excluded App (optional)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AddActExcludedProcessTxt" Height="32"/>
                                </StackPanel>
                                <Button Grid.Column="5" Content="Pick..." Style="{StaticResource SecondaryButton}" Click="PickExcludedActApp_Click" VerticalAlignment="Bottom" Height="32" Margin="0,0,10,0"/>
                                <Button Grid.Column="6" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseExcludedActApp_Click" VerticalAlignment="Bottom" Height="32"/>

                                <Button Grid.Column="8" Content="Add Action" Style="{StaticResource PrimaryButton}" Click="AddAction_Click" VerticalAlignment="Bottom" Height="32" Padding="20,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Settings -->
            <TabItem Header="Settings">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,0,20">
                            <!-- Toggle Options -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Behavior Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                                    
                                    <CheckBox x:Name="SuppressKeysChk" Content="Suppress keyboard input while recording" Foreground="#F2F2F7" Margin="0,0,0,12" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <TextBlock Text="If checked, the keys you type after Left Ctrl will not be sent to the active application until you cancel or submit." Foreground="#8E8E93" FontSize="11" Margin="20,0,0,15"/>

                                    <CheckBox x:Name="ShowOverlayChk" Content="Show screen overlay HUD while recording" Foreground="#F2F2F7" Margin="0,0,0,12" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <TextBlock Text="Displays a small overlay at the bottom right showing current typed trigger." Foreground="#8E8E93" FontSize="11" Margin="20,0,0,15"/>

                                    <CheckBox x:Name="RunAtStartupChk" Content="Start KeyMapper automatically with Windows" Foreground="#F2F2F7" Checked="SettingChanged" Unchecked="SettingChanged" Margin="0,0,0,12"/>
                                    <TextBlock Text="Adds application shortcut to the current user's registry run path." Foreground="#8E8E93" FontSize="11" Margin="20,0,0,15"/>

                                    <CheckBox x:Name="PlaySoundsChk" Content="Enable audio feedback (ticks and chimes)" Foreground="#F2F2F7" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <TextBlock Text="Plays mechanical click sounds when recording, and a chime when a shortcut triggers." Foreground="#8E8E93" FontSize="11" Margin="20,0,0,5"/>
                                </StackPanel>
                            </Border>

                            <!-- Backup & Restore -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Backup &amp; Restore Mappings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Export your expansions and actions to a file, or import from an existing backup." Foreground="#8E8E93" FontSize="11" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Export Mappings..." Style="{StaticResource SecondaryButton}" Click="ExportMappings_Click" Margin="0,0,12,0" Padding="15,0" Height="32"/>
                                        <Button Content="Import Mappings..." Style="{StaticResource SecondaryButton}" Click="ImportMappings_Click" Padding="15,0" Height="32"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Exclusions -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Exclusions (Disable in these apps)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    
                                    <ListView x:Name="ExclusionsList" Grid.Row="1" Height="120" Background="#2C2C2E" BorderThickness="0" Margin="0,0,0,10" Padding="5">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding}" Foreground="#E5E5EA" FontSize="13" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Click="DeleteExclusion_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                                        <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="#FF453A" Width="12" Height="12" Stretch="Uniform"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AddExclusionTxt" Margin="0,0,10,0"/>
                                        <Button Grid.Column="1" Content="Add App" Style="{StaticResource SecondaryButton}" Click="AddExclusion_Click" Height="30" Padding="12,0" Margin="0,0,10,0"/>
                                        <Button Grid.Column="2" Content="Select Running Apps..." Style="{StaticResource SecondaryButton}" Click="SelectExclusionApps_Click" Height="30" Padding="12,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 4: User Guide -->
            <TabItem Header="User Guide">
                <Grid Margin="0,15,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel Margin="0,0,0,20">
                            <!-- Welcome Header -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Welcome to KeyMapper" FontSize="20" FontWeight="Bold" Foreground="#007AFF" Margin="0,0,0,8"/>
                                    <TextBlock Text="KeyMapper is a lightweight, background-running productivity assistant that transforms short text abbreviations into long-form templates, runs application actions, and executes dynamic text functions on the fly." Foreground="#E5E5EA" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Modes of Operation -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="1. Modes of Operation" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="• Auto-Expand Mode (Trigger Character)" FontWeight="SemiBold" Foreground="#30D158" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock Text="Type your abbreviation followed by a semicolon (e.g. typing 'mail;' where 'mail' is mapped). The abbreviation is instantly erased and replaced by your expanded text. Perfect for fast, uninterrupted typing." Foreground="#8E8E93" FontSize="12" TextWrapping="Wrap" Margin="10,0,0,12" LineHeight="16"/>

                                    <TextBlock Text="• Standard Mode (Interception Buffer)" FontWeight="SemiBold" Foreground="#30D158" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock Text="Tap Left Ctrl (starts recording a mechanical click sound) → Type your abbreviation (e.g. 'mail') → Tap Right Ctrl (submits). The text is replaced. To cancel recording, tap Left Ctrl again." Foreground="#8E8E93" FontSize="12" TextWrapping="Wrap" Margin="10,0,0,0" LineHeight="16"/>
                                </StackPanel>
                            </Border>

                            <!-- Text Expansions & Macros -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="2. Dynamic Macros (Placeholders)" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                                    <TextBlock Text="You can insert dynamic placeholders into your expansions. Click the chips below the target input fields to insert:" Foreground="#E5E5EA" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    
                                    <TextBlock Text="• {date}: Inserts the current local date (e.g. 2026-07-20)." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {time}: Inserts the current local time (e.g. 23:51)." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {clip}: Pastes the current contents of your clipboard." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {sel}: Grabs the active text selection and inserts it." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• {cursor}: Places your keyboard cursor at this position after pasting." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Text Functions -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="3. Text Functions (fn:)" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                                    <TextBlock Text="Prefix your expansion target with 'fn:' to turn it into a dynamic text function. You can run these on text selection or immediately in Auto-Expand mode (e.g. type '12*4fc;' where 'fc' maps to 'fn:calc'):" Foreground="#E5E5EA" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="18"/>
                                    
                                    <Grid Margin="10,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="fn:upper" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Converts text to UPPERCASE." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="fn:lower" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Converts text to lowercase." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="fn:title" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Converts text to Title Case (Capitalizes Words)." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="fn:rev / fn:reverse" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Reverses the text string (e.g. 'hello' → 'olleh')." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="fn:len" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Returns the character length of the input." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="fn:calc" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Evaluates mathematical expressions (e.g. '12*3' → '36')." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="fn:morse / fn:mc" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Converts text to Morse Code." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="fn:unmorse / fn:umc" Foreground="#007AFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="Translates Morse Code back to text (supports Unicode middle dots, bullets, and dashes)." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,4"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Scope Control -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="4. Scope Control (Allowed / Excluded Apps)" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                                    <TextBlock Text="You can define which programs are allowed or excluded for each specific shortcut, or exclude apps globally in the Settings tab." Foreground="#E5E5EA" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="18"/>
                                    
                                    <TextBlock Text="• Allowed App: The shortcut will ONLY trigger when this program is active." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Excluded App: The shortcut will trigger everywhere EXCEPT in this program." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Pick Button: Choose from a list of currently running windows." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Browse Button: Select the executable file (.exe) path from your disk." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Shortcuts and Controls -->
                            <Border Background="#1C1C1E" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="5. Global Shortcuts &amp; Operations" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="• Ctrl + Alt + P: Global Pause/Resume shortcut. Swallows keys so it doesn't type." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Scroll Lock: Alternative Pause/Resume toggle key." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,4"/>
                                    <TextBlock Text="• Minimize Window: Closing the main window automatically minimizes it to the system tray. Use the tray icon menu to open the dashboard or fully Exit." Foreground="#8E8E93" FontSize="12" Margin="10,0,0,0" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

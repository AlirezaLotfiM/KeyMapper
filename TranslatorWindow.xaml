<Window x:Class="KeyMapper.TranslatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pet Translator"
        Width="500"
        Height="620"
        MinHeight="520"
        MaxHeight="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PixelButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource PixelButton}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  SnapsToDevicePixels="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LanguageChip" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chip"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AppAccentSoftBrush}"/>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="3"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="6" Color="#6B5A3A" Opacity="0.35"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="7"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#55CAD3"/>
                <Border Grid.Column="1" Background="#F3BE55"/>
                <Border Grid.Column="2" Background="#E985AE"/>
            </Grid>

            <Grid Grid.Row="1" Margin="24,20,20,18"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Live translator" Foreground="{DynamicResource AppTextBrush}"
                               FontFamily="Segoe UI" FontSize="19" FontWeight="SemiBold"/>
                    <TextBlock Text="Type normally. Translation updates by itself."
                               Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource PixelButton}"
                        Padding="12,8" Margin="0,0,10,0" Click="ToggleSettingsButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z"
                                      Stroke="#30445E" StrokeThickness="1.7"/>
                                <Path Data="M2 12.8799V11.1199C2 10.0799 2.85 9.21994 3.9 9.21994C5.71 9.21994 6.45 7.93994 5.54 6.36994C5.02 5.46994 5.33 4.29994 6.24 3.77994L7.97 2.78994C8.76 2.31994 9.78 2.59994 10.25 3.38994L10.36 3.57994C11.26 5.14994 12.74 5.14994 13.65 3.57994L13.76 3.38994C14.23 2.59994 15.25 2.31994 16.04 2.78994L17.77 3.77994C18.68 4.29994 18.99 5.46994 18.47 6.36994C17.56 7.93994 18.3 9.21994 20.11 9.21994C21.15 9.21994 22.01 10.0699 22.01 11.1199V12.8799C22.01 13.9199 21.16 14.7799 20.11 14.7799C18.3 14.7799 17.56 16.0599 18.47 17.6299C18.99 18.5399 18.68 19.6999 17.77 20.2199L16.04 21.2099C15.25 21.6799 14.23 21.3999 13.76 20.6099L13.65 20.4199C12.75 18.8499 11.27 18.8499 10.36 20.4199L10.25 20.6099C9.78 21.3999 8.76 21.6799 7.97 21.2099L6.24 20.2199C5.33 19.6999 5.02 18.5299 5.54 17.6299C6.45 16.0599 5.71 14.7799 3.9 14.7799C2.85 14.7799 2 13.9199 2 12.8799Z"
                                      Stroke="#30445E" StrokeThickness="1.7" StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource IconButton}"
                        Width="44" Height="44"
                        Foreground="#B53D64" BorderBrush="#D795AA" Click="CloseButton_Click"
                        ToolTip="Close translator">
                    <Grid Width="24" Height="24">
                        <Path Width="12" Height="12"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Fill"
                              Data="M18 18L12 12M12 12L6 6M12 12L18 6M12 12L6 18"
                              Stroke="#B53D64"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Grid>
                </Button>
            </Grid>

            <ScrollViewer x:Name="BodyScrollViewer" Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          CanContentScroll="False">
                <StackPanel>
            <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,2,0,2" Padding="24,16">
                <StackPanel>
                    <TextBlock Text="Translate into" Foreground="{DynamicResource AppTextBrush}"
                               FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="EnglishTarget" GroupName="TargetLanguage" Content="ENGLISH"
                                     Tag="en" IsChecked="True" Style="{StaticResource LanguageChip}" Checked="TargetLanguage_Checked"/>
                        <RadioButton x:Name="GermanTarget" GroupName="TargetLanguage" Content="GERMAN"
                                     Tag="de" Style="{StaticResource LanguageChip}" Checked="TargetLanguage_Checked"/>
                        <RadioButton x:Name="PersianTarget" GroupName="TargetLanguage" Content="PERSIAN"
                                     Tag="fa" Style="{StaticResource LanguageChip}" Checked="TargetLanguage_Checked"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Margin="24,20,24,0">
                <TextBlock Text="Your text" Foreground="{DynamicResource AppMutedTextBrush}" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="SourceTextBox" Height="92" Style="{StaticResource EditorBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         TextChanged="SourceTextBox_TextChanged"/>
            </StackPanel>

            <Grid Margin="24,14,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#D4F1E2" BorderBrush="#53A77D" BorderThickness="2"
                        Padding="8,4" Margin="0,0,12,0">
                    <TextBlock Text="Live" Foreground="#246548" FontFamily="Segoe UI"
                               FontWeight="SemiBold" FontSize="10"/>
                </Border>
                <TextBlock x:Name="StatusText" Grid.Column="1" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11"
                           Text="Waiting for text" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <StackPanel Margin="24,18,24,0">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Translation" Foreground="{DynamicResource AppMutedTextBrush}" FontFamily="Segoe UI"
                               FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource IconButton}"
                            Width="40" Height="36"
                            ToolTip="Copy translation" Click="CopyButton_Click">
                        <Viewbox Width="18" Height="18"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M6 11C6 8.17157 6 6.75736 6.87868 5.87868C7.75736 5 9.17157 5 12 5H15C17.8284 5 19.2426 5 20.1213 5.87868C21 6.75736 21 8.17157 21 11V16C21 18.8284 21 20.2426 20.1213 21.1213C19.2426 22 17.8284 22 15 22H12C9.17157 22 7.75736 22 6.87868 21.1213C6 20.2426 6 18.8284 6 16V11Z"
                                      Stroke="#30445E" StrokeThickness="1.7"/>
                                <Path Data="M6 19C4.34315 19 3 17.6569 3 16V10C3 6.22876 3 4.34315 4.17157 3.17157C5.34315 2 7.22876 2 11 2H15C16.6569 2 18 3.34315 18 5"
                                      Stroke="#6B7B8F" StrokeThickness="1.7" Opacity="0.65"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
                <TextBox x:Name="ResultTextBox" Height="92" Style="{StaticResource EditorBox}"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Foreground="{DynamicResource AppTextBrush}"/>
            </StackPanel>

            <Border x:Name="ServerSettingsPanel" Visibility="Collapsed"
                    Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,2,0,0"
                    Padding="24,20,34,24" Margin="0,20,0,0">
                <StackPanel>
                        <TextBlock Text="Translation service" Foreground="{DynamicResource AppTextBrush}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Local LibreTranslate starts automatically. You normally do not need to change anything."
                                   Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,14"/>
                        <Expander Header="Use another LibreTranslate server (optional)"
                                  Foreground="{DynamicResource AppTextBrush}" FontSize="11">
                            <StackPanel Margin="0,12,0,6">
                                <TextBlock Text="Server address" Foreground="{DynamicResource AppMutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="EndpointTextBox" Style="{StaticResource EditorBox}"
                                         Height="38" Padding="9,6" FontFamily="Segoe UI" FontSize="11"
                                         TextChanged="AdvancedSetting_Changed"/>
                                <TextBlock Text="API key (only if that server requires one)"
                                           Foreground="{DynamicResource AppMutedTextBrush}" FontWeight="SemiBold" Margin="0,14,0,6"/>
                                <PasswordBox x:Name="ApiKeyBox"
                                             Height="38"
                                             Background="{DynamicResource AppInputBrush}" Foreground="{DynamicResource AppTextBrush}"
                                             BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2"
                                             Padding="9,6" FontFamily="Segoe UI" FontSize="11"
                                             PasswordChanged="AdvancedSetting_Changed"/>
                            </StackPanel>
                        </Expander>
                </StackPanel>
            </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>

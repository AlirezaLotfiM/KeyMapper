<Window x:Class="KeyMapper.AssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Talk with your desktop companion"
        Width="760"
        Height="700"
        MinWidth="620"
        MinHeight="540"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="AssistantButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PromptChip" TargetType="Button" BasedOn="{StaticResource AssistantButton}">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="SquareAssistantButton" TargetType="Button" BasedOn="{StaticResource AssistantButton}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="3">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="6" Color="#6B5A3A" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="7"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#55CAD3"/>
                <Border Grid.Column="1" Background="#F3BE55"/>
                <Border Grid.Column="2" Background="#E985AE"/>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="24,17,20,16"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="76"
                        Height="76"
                        Margin="0,0,16,0"
                        Background="{DynamicResource AppAccentSoftBrush}"
                        BorderBrush="{DynamicResource AppAccentBrush}"
                        BorderThickness="2">
                    <Image x:Name="CharacterPortrait"
                           Width="66"
                           Height="66"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="WindowTitleText"
                                   Text="Talk with your companion"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="23"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Border Margin="12,1,0,0"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppAccentSoftBrush}"
                                BorderBrush="{DynamicResource AppAccentBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6"
                                         Margin="0,0,6,0"
                                         Fill="{DynamicResource AppAccentBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="MoodText"
                                           Text="PRESENT"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="9"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="CharacterRoleText"
                               Foreground="{DynamicResource AppAccentBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                    <TextBlock x:Name="CharacterTaglineText"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="ClearMemoryButton"
                            MinWidth="110"
                            Height="44"
                            Margin="0,0,9,0"
                            Padding="11,0"
                            Style="{StaticResource AssistantButton}"
                            ToolTip="Start fresh and forget this character's saved conversation"
                            Click="ClearMemoryButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14"
                                  Margin="0,0,7,0"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource AppMutedTextBrush}"
                                  Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z"/>
                            <TextBlock x:Name="ClearMemoryText" Text="New chat" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SquareAssistantButton}"
                            BorderBrush="#D795AA"
                            ToolTip="Close conversation"
                            Click="CloseButton_Click">
                        <Path Width="14" Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Fill"
                              Data="M18 18L12 12M12 12L6 6M12 12L18 6M12 12L6 18"
                              Stroke="#B53D64"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Margin="0,14,0,0"
                        Padding="11,8"
                        Background="{DynamicResource AppSurfaceAltBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Path Width="15" Height="15"
                              Margin="0,0,9,0"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Fill="{DynamicResource AppAccentBrush}"
                              Data="M12,2A10,10 0 0,0 2,12C2,17.5 6.5,22 12,22C17.5,22 22,17.5 22,12A10,10 0 0,0 12,2M12,4C16.4,4 20,7.6 20,12C20,16.4 16.4,20 12,20C7.6,20 4,16.4 4,12C4,7.6 7.6,4 12,4M11,7V13H13V7H11M11,15V17H13V15H11Z"/>
                        <TextBlock x:Name="ContextText"
                                   Grid.Column="1"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="MemoryStatusText"
                                   Grid.Column="2"
                                   Margin="14,0,0,0"
                                   Foreground="{DynamicResource AppAccentBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="24,0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer x:Name="ConversationScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="18,18,18,8">
                        <StackPanel x:Name="ConversationPanel"/>
                    </ScrollViewer>

                    <Border x:Name="TypingIndicator"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Margin="18,4,18,14"
                            Padding="11,8"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Margin="0,0,8,0"
                                     Fill="{DynamicResource AppAccentBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="TypingText"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Margin="24,16,24,24"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="2"
                    Padding="15,13">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Keep the conversation going"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,0,7"/>
                    <WrapPanel x:Name="QuickPromptPanel" Grid.Row="1" Margin="0,0,0,4"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="PromptTextBox"
                                     MinHeight="54"
                                     MaxHeight="110"
                                     Background="{DynamicResource AppInputBrush}"
                                     Foreground="{DynamicResource AppTextBrush}"
                                     CaretBrush="{DynamicResource AppAccentBrush}"
                                     BorderBrush="{DynamicResource AppBorderBrush}"
                                     BorderThickness="2"
                                     Padding="12,10"
                                     FontFamily="Segoe UI"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                                     TextChanged="PromptTextBox_TextChanged"/>
                            <TextBlock x:Name="PromptPlaceholder"
                                       Text="Say something naturally, or ask for an app, game, or website..."
                                       Margin="14,0,12,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Button x:Name="SendButton"
                                Grid.Column="1"
                                MinWidth="96"
                                Margin="10,0,0,0"
                                Background="{DynamicResource AppAccentSoftBrush}"
                                BorderBrush="{DynamicResource AppAccentBrush}"
                                Style="{StaticResource AssistantButton}"
                                Click="SendButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Send" VerticalAlignment="Center"/>
                                <Path Width="14" Height="14"
                                      Margin="9,0,0,0"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource AppTextBrush}"
                                      Data="M2,21L23,12L2,3V10L17,12L2,14V21Z"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Margin="0,6,0,0"
                               Text="Enter to send  ·  Shift+Enter for a new line"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="9"
                               HorizontalAlignment="Right"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
